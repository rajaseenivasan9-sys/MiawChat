<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme for Chat Activity to appear as bottom sheet modal -->
    <style name="ChatActivityTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Transparent background -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">#1E88E5</item>
        <item name="android:navigationBarColor">@android:color/white</item>
        <!-- Make activity floating/dialog-like -->
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>
